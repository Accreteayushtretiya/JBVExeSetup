{
  "name": "jbv-react-app",
  "version": "1.0.0",
  "description": "JBV React Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:portable": "electron-builder --win portable"
  },
  "author": "JBV",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.2.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "your-github-username",
        "repo": "your-github-repo-name"
      }
    ],
    "appId": "com.jbv.reactapp",
    "productName": "JBV React App",
    "directories": {
      "output": "output"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
