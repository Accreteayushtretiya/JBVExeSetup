{
  "name": "FMS-Production-App",
  "version": "1.0.1",
  "description": "FMS Production Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:portable": "electron-builder --win portable"
  },
  "author": "FMS Production Application",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.989.0",
    "@aws-sdk/s3-request-presigner": "^3.989.0",
    "amqplib": "^0.10.9",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "base-x": "^5.0.1",
    "bullmq": "^5.69.1",
    "cookie-parser": "^1.4.7",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "electron-edge-js": "^40.0.1",
    "electron-updater": "^6.2.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "koffi": "^2.15.1",
    "moment": "^2.30.1",
    "multer": "^2.0.2",
    "mysql2": "^3.17.1",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.1.11",
    "puppeteer": "^24.37.2",
    "sequelize": "^6.37.7",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^8.3.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.jbv.reactapp",
    "productName": "FMS Production App",
    "directories": {
      "output": "output"
    },

    "asar": true,

    "asarUnpack": [
      "print-server/config/*.dll",
      "print-server/lib/**/*",
      "node_modules/sharp/**/*",
      "node_modules/electron-edge-js/**/*",
      "node_modules/mysql2/**/*",
      "node_modules/bcrypt/**/*",
      "node_modules/puppeteer/**/*",
      "node_modules/koffi/**/*"
    ],

    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "print-server/**/*",
      "package.json"
    ],

    "extraResources": [
      {
        "from": "print-server/config/tsclibnet.dll",
        "to": "tsclibnet.dll"
      }
    ],

    "win": {
      "icon": "siteIcon.ico",
      "signingHashAlgorithms": ["sha256"],
      "sign": "./sign.js",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "siteIcon.ico",
  "uninstallerIcon": "siteIcon.ico",
  "installerHeaderIcon": "siteIcon.ico"
    },

    "publish": [
      {
        "provider": "github",
        "owner": "Accreteayushtretiya",
        "repo": "JBVExeSetup"
      }
    ]
  }
}
